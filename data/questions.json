        {
          "key": "C",
          "text": "先问几排几座、能不能堵球员通道、场馆 WiFi 和最近精酿店——你看球像在执行重度线下项目",
          "scores": {
            "A": 3,
            "S": 2,
            "L": 2
          },
          "signatures": {
            "ATM": 3
          }
        }
